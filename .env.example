# =============================================================================
# AISOS — environment configuration
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure OpenAI (required)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-01

# Single shared deployment name — used for both chat and embeddings unless the
# per-purpose overrides below are set. Matches AZURE_OPENAI_DEPLOYMENT used by
# other internal apps.
AZURE_OPENAI_DEPLOYMENT=

# Optional: override per purpose. Leave blank to fall back to the value above.
AZURE_OPENAI_DEPLOYMENT_CHAT=
AZURE_OPENAI_DEPLOYMENT_EMBED=

# -----------------------------------------------------------------------------
# AISOS runtime
# -----------------------------------------------------------------------------
AISOS_DB_PATH=./aisos.db
AISOS_CONFIG_PATH=./config.toml

# -----------------------------------------------------------------------------
# Azure Sentinel / Log Analytics (optional)
# Required for log_analytics_query and log_analytics_describe_table tools.
# Create a Service Principal with "Log Analytics Reader" on the workspace.
# -----------------------------------------------------------------------------
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_WORKSPACE_ID=

# -----------------------------------------------------------------------------
# Threat intelligence API keys (optional)
# Tools are skipped gracefully if the corresponding key is blank.
# -----------------------------------------------------------------------------

# VirusTotal — https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# AlienVault OTX — https://otx.alienvault.com/api
ALIENVAULT_OTX_API_KEY=

# NIST NVD — https://nvd.nist.gov/developers/request-an-api-key
# Unauthenticated requests work but are rate-limited to 5 req/30 s.
NVD_API_KEY=
