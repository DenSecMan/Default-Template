# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-02-01

# Single shared deployment (used for both chat AND embeddings unless overridden below).
# Equivalent to the AZURE_OPENAI_DEPLOYMENT var used by other internal apps.
AZURE_OPENAI_DEPLOYMENT=

# Optional: override per-purpose. Leave blank to fall back to AZURE_OPENAI_DEPLOYMENT.
AZURE_OPENAI_DEPLOYMENT_CHAT=
AZURE_OPENAI_DEPLOYMENT_EMBED=

# AISOS runtime
AISOS_DB_PATH=./aisos.db
